    <template id="report_candidate_epe_template">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="ar_recrutement.report_araymond_external_layout">
                <div class="page">

                    <style>
                        .fa-title {
                            text-align: center;
                            font-size: 22px;
                            font-weight: bold;
                            margin-bottom: 18px;
                            border-bottom: 2px solid #444;
                            padding-bottom: 8px;
                        }
                        .fa-subtitle {
                            font-size: 15px;
                            font-weight: bold;
                            background: #e9ecef;
                            padding: 8px 10px;
                            margin-top: 18px;
                            margin-bottom: 0;
                            border: 1px solid #cfd4da;
                        }
                        .fa-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-bottom: 14px;
                        }
                        .fa-table td, .fa-table th {
                            border: 1px solid #cfd4da;
                            padding: 8px;
                            vertical-align: top;
                            font-size: 12px;
                        }
                        .fa-label {
                            width: 35%;
                            font-weight: bold;
                            background: #f8f9fa;
                        }
                        .fa-value {
                            width: 65%;
                        }
                    </style>

                    <div class="fa-title">EVALUATION DE LA PERIODE D'ESSAI</div>

                    <h3 class="fa-subtitle">Identification du salarié</h3>
                    <table class="fa-table">
                        <tr>
                            <td class="fa-label">Nom &amp; Prénom</td>
                            <td class="fa-value"><span t-esc="o.epe_nom_prenom or ''"/></td>
                        </tr>
                        <tr>
                            <td class="fa-label">Poste</td>
                            <td class="fa-value"><span t-esc="o.epe_poste or ''"/></td>
                        </tr>
                        <tr>
                            <td class="fa-label">Date d'entrée en fonction</td>
                            <td class="fa-value"><span t-esc="o.epe_date_entree_fonction or ''"/></td>
                        </tr>
                        <tr>
                            <td class="fa-label">Affectation</td>
                            <td class="fa-value"><span t-esc="o.epe_affectation_id.name or ''"/></td>
                        </tr>
                        <tr>
                            <td class="fa-label">Evaluateur</td>
                            <td class="fa-value"><span t-esc="o.epe_evaluateur_id.name or ''"/></td>
                        </tr>
                        <tr>
                            <td class="fa-label">Date d'évaluation</td>
                            <td class="fa-value"><span t-esc="o.epe_date_evaluation or ''"/></td>
                        </tr>
                    </table>

                    <h3 class="fa-subtitle">Points Forts / Points à améliorer</h3>
                    <table class="fa-table">
                        <tr>
                            <th>Points Forts</th>
                            <th>Points à améliorer</th>
                        </tr>
                        <tr>
                            <td><span t-esc="o.epe_points_forts or ''"/></td>
                            <td><span t-esc="o.epe_points_ameliorer or ''"/></td>
                        </tr>
                    </table>

                    <h3 class="fa-subtitle">Principales missions et réalisations accomplies durant la période de probation</h3>
                    <table class="fa-table">
                        <tr>
                            <td><span t-esc="o.epe_missions_realisation or ''"/></td>
                        </tr>
                    </table>

                    <h3 class="fa-subtitle">Critère d'Appréciation</h3>
                    <table class="fa-table">
                        <tr>
                            <th>Atteinte des résultats/objectifs</th>
                            <th>Potentiel pour le développement</th>
                            <th>Maitrise technique</th>
                            <th>Capacité d'adaptation</th>
                            <th>Engagement et dynamisme</th>
                            <th>Autonomie et prise d'initiative</th>
                            <th>Commentaire</th>
                        </tr>
                        <tr>
                            <td><span t-esc="dict(o._fields['epe_atteinte_resultats'].selection).get(o.epe_atteinte_resultats, '')"/></td>
                            <td><span t-esc="dict(o._fields['epe_potentiel_developpement'].selection).get(o.epe_potentiel_developpement, '')"/></td>
                            <td><span t-esc="dict(o._fields['epe_maitrise_technique'].selection).get(o.epe_maitrise_technique, '')"/></td>
                            <td><span t-esc="dict(o._fields['epe_capacite_adaptation'].selection).get(o.epe_capacite_adaptation, '')"/></td>
                            <td><span t-esc="dict(o._fields['epe_engagement_dynamisme'].selection).get(o.epe_engagement_dynamisme, '')"/></td>
                            <td><span t-esc="dict(o._fields['epe_autonomie_initiative'].selection).get(o.epe_autonomie_initiative, '')"/></td>
                            <td><span t-esc="o.epe_commentaire or ''"/></td>
                        </tr>
                    </table>

                    <h3 class="fa-subtitle">Autres Remarques</h3>
                    <table class="fa-table">
                        <tr>
                            <td><span t-esc="o.epe_autres_remarques or ''"/></td>
                        </tr>
                    </table>

                </div>
            </t>
        </t>
    </t>
</template>

<template id="report_candidate_integration_template">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="ar_recrutement.report_araymond_external_layout">
                <div class="page">

                    <style>
                        .int-title {
                            text-align: center;
                            font-size: 22px;
                            font-weight: bold;
                            margin-bottom: 18px;
                            border-bottom: 2px solid #444;
                            padding-bottom: 8px;
                        }
                        .int-subtitle {
                            font-size: 15px;
                            font-weight: bold;
                            background: #e9ecef;
                            padding: 8px 10px;
                            margin-top: 18px;
                            margin-bottom: 0;
                            border: 1px solid #cfd4da;
                        }
                        .int-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-bottom: 14px;
                        }
                        .int-table td, .int-table th {
                            border: 1px solid #cfd4da;
                            padding: 8px;
                            vertical-align: top;
                            font-size: 12px;
                        }
                        .int-label {
                            width: 35%;
                            font-weight: bold;
                            background: #f8f9fa;
                        }
                        .int-value {
                            width: 65%;
                        }
                        .text-center {
                            text-align: center;
                        }
                    </style>

                    <div class="int-title">FORMULAIRE D'INTEGRATION</div>

                    <h3 class="int-subtitle">Informations générales</h3>
                    <table class="int-table">
                        <tr>
                            <td class="int-label">Nom des candidats</td>
                            <td class="int-value">
                                <span t-esc="o.candidate_name or ''"/>
                            </td>
                        </tr>
                        <tr>
                            <td class="int-label">Département</td>
                            <td class="int-value">
                                <span t-esc="o.integration_department_id.name or ''"/>
                            </td>
                        </tr>
                    </table>

                    <h3 class="int-subtitle">Partie I</h3>
                    <table class="int-table">
                        <thead>
                            <tr>
                                <th>Département ou Service accueillant</th>
                                <th>Rubrique / Étape</th>
                                <th>Tuteur</th>
                                <th>Dates</th>
                                <th>Commentaire</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.integration_line_ids" t-as="line">
                                <tr>
                                    <td>
                                        <span t-esc="dict(line._fields['service_accueillant'].selection).get(line.service_accueillant, '')"/>
                                    </td>
                                    <td>
                                        <span t-esc="line.rubrique or ''"/>
                                    </td>
                                    <td>
                                        <span t-esc="line.tuteur_id.name or ''"/>
                                    </td>
                                    <td>
                                        <span t-esc="line.date_integration or ''"/>
                                    </td>
                                    <td>
                                        <span t-esc="line.commentaire or ''"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                </div>
            </t>
        </t>
    </t>
</template>

