                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Capacité de négociation et persuasion</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_negociation_persuasion'].selection).get(o.fa_negociation_persuasion, '')"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Esprit d’équipe / Esprit de leadership</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_esprit_equipe_leadership'].selection).get(o.fa_esprit_equipe_leadership, '')"/>
                                </td>
                            </tr>
                        </table>

                        <h3 class="fa-subtitle">SAVOIR-ETRE</h3>
                        <table class="fa-table">
                            <tr>
                                <td class="fa-label">Autonomie</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_autonomie'].selection).get(o.fa_autonomie, '')"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Dynamisme</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_dynamisme'].selection).get(o.fa_dynamisme, '')"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Réactivité</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_reactivite'].selection).get(o.fa_reactivite, '')"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Engagement</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_engagement'].selection).get(o.fa_engagement, '')"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Rigueur</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_rigueur'].selection).get(o.fa_rigueur, '')"/>
                                </td>
                            </tr>
                        </table>

                        <h3 class="fa-subtitle">Situation professionnelle actuelle</h3>
                        <table class="fa-table">
                            <tr>
                                <td class="fa-label">Actuellement en poste</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_actuellement_en_poste'].selection).get(o.fa_actuellement_en_poste, '')"/>
                                </td>
                            </tr>

                            <t t-if="o.fa_actuellement_en_poste == 'oui'">
                                <tr>
                                    <td class="fa-label">Fonction actuelle</td>
                                    <td class="fa-value">
                                        <span t-esc="o.fa_fonction_actuelle or ''"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fa-label">Entreprise actuelle</td>
                                    <td class="fa-value">
                                        <span t-esc="o.fa_entreprise_actuelle or ''"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fa-label">Salaire actuel</td>
                                    <td class="fa-value">
                                        <span t-esc="o.fa_salaire_actuel or ''"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fa-label">Préavis</td>
                                    <td class="fa-value">
                                        <span t-esc="o.fa_preavis or ''"/>
                                    </td>
                                </tr>
                            </t>
                        </table>

                        <h3 class="fa-subtitle">Conclusion</h3>
<table class="fa-table">
    <tr>
        <td class="fa-label">Prétentions salariales</td>
        <td class="fa-value">
            <span t-esc="o.fa_pretentions_salariales_num or ''"/>
        </td>
    </tr>
    <tr>
        <td class="fa-label">Appréciations et motivations générales</td>
        <td class="fa-value">
            <span t-esc="o.fa_appreciations_generales or ''"/>
        </td>
    </tr>
    <tr>
    <td class="fa-label">Note globale</td>
    <td class="fa-value">
        <span t-esc="'%.2f' % (o.fa_note_globale or 0.0)"/>
    </td>
</tr>
</table>

                    </div>
                </t>
            </t>
        </t>
    </template>

