<odoo>

    <record id="paperformat_candidate_appreciation" model="report.paperformat">
        <field name="name">ARaymond - Appreciation Reports</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">42</field>
        <field name="margin_bottom">24</field>
        <field name="margin_left">12</field>
        <field name="margin_right">12</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">8</field>
        <field name="dpi">90</field>
    </record>

    <!-- ===================================================== -->
    <!-- ACTION REPORT FA -->
    <!-- ===================================================== -->
    <record id="action_report_candidate_fa" model="ir.actions.report">
        <field name="name">Fiche d'appréciation Technique</field>
        <field name="model">ar.demande.recrutement.candidate</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ar_recrutement.report_candidate_fa_template</field>
        <field name="report_file">ar_recrutement.report_candidate_fa_template</field>
        <field name="paperformat_id" ref="ar_recrutement.paperformat_candidate_appreciation"/>
        <field name="print_report_name">'FA - %s' % (object.candidate_name or 'Candidat')</field>
    </record>

    <!-- ===================================================== -->
    <!-- ACTION REPORT FA RH -->
    <!-- ===================================================== -->
    <record id="action_report_candidate_rhfa" model="ir.actions.report">
        <field name="name">Fiche d'appréciation RH</field>
        <field name="model">ar.demande.recrutement.candidate</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ar_recrutement.report_candidate_rhfa_template</field>
        <field name="report_file">ar_recrutement.report_candidate_rhfa_template</field>
        <field name="paperformat_id" ref="ar_recrutement.paperformat_candidate_appreciation"/>
        <field name="print_report_name">'FA RH - %s' % (object.candidate_name or 'Candidat')</field>
    </record>

    <!-- ===================================================== -->
    <!-- ACTION REPORT EPE -->
    <!-- ===================================================== -->
    <record id="action_report_candidate_epe" model="ir.actions.report">
    <field name="name">Evaluation de la péridode d'essai</field>
    <field name="model">ar.demande.recrutement.candidate</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">ar_recrutement.report_candidate_epe_template</field>
    <field name="report_file">ar_recrutement.report_candidate_epe_template</field>
    <field name="paperformat_id" ref="ar_recrutement.paperformat_candidate_appreciation"/>
    <field name="print_report_name">'EPE - %s' % (object.candidate_name or 'Candidat')</field>
</record>

    <!-- ===================================================== -->
    <!-- ACTION REPORT Intégration -->
    <!-- ===================================================== -->
<record id="action_report_candidate_integration" model="ir.actions.report">
    <field name="name">Formulaire d'intégration</field>
    <field name="model">ar.demande.recrutement.integration</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">ar_recrutement.report_candidate_integration_template</field>
    <field name="report_file">ar_recrutement.report_candidate_integration_template</field>
    <field name="print_report_name">'Integration - %s' % (object.candidate_name or 'Candidat')</field>
</record>

    <!-- ===================================================== -->
    <!-- TEMPLATE FA -->
    <!-- ===================================================== -->
    <template id="report_candidate_fa_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="ar_recrutement.report_araymond_external_layout">
                    <div class="page">

                        <style>
                            .fa-title {
                                text-align: center;
                                font-size: 22px;
                                font-weight: bold;
                                margin-bottom: 18px;
                                border-bottom: 2px solid #444;
                                padding-bottom: 8px;
                            }
                            .fa-subtitle {
                                font-size: 15px;
                                font-weight: bold;
                                background: #e9ecef;
                                padding: 8px 10px;
                                margin-top: 18px;
                                margin-bottom: 0;
                                border: 1px solid #cfd4da;
                            }
                            .fa-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 14px;
                            }
                            .fa-table td {
                                border: 1px solid #cfd4da;
                                padding: 8px;
                                vertical-align: top;
                                font-size: 12px;
                            }
                            .fa-label {
                                width: 42%;
                                font-weight: bold;
                                background: #f8f9fa;
                            }
                            .fa-value {
                                width: 58%;
                            }
                            .fa-block {
                                margin-bottom: 8px;
                            }
                        </style>

                        <div class="fa-title">FICHE D'APPRECIATION TECHNIQUE</div>

                        <h3 class="fa-subtitle">Informations générales</h3>
                        <table class="fa-table">
                            <tr>
                                <td class="fa-label">Candidat</td>
                                <td class="fa-value">
                                    <span t-esc="o.candidate_name or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Entretien réalisé par</td>
                                <td class="fa-value">
                                    <span t-esc="o.fa_interview_realisee_par.name or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Date d’entretien</td>
                                <td class="fa-value">
                                    <span t-esc="o.fa_date_entretien or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Présentation générale</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_presentation_generale'].selection).get(o.fa_presentation_generale, '')"/>
                                </td>
                            </tr>
                        </table>

                        <h3 class="fa-subtitle">SAVOIR</h3>
                        <table class="fa-table">
                            <tr>
                                <td class="fa-label">Formation initiale</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_formation_initiale'].selection).get(o.fa_formation_initiale, '')"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Formation complémentaire</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_formation_complementaire_eval'].selection).get(o.fa_formation_complementaire_eval, '')"/>
                                </td>
                            </tr>
                        </table>

                        <h3 class="fa-subtitle">SAVOIR-FAIRE</h3>
                        <table class="fa-table">
                            <tr>
                                <td class="fa-label">Expériences professionnelles / Compétences métiers</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_experiences_professionnelles'].selection).get(o.fa_experiences_professionnelles, '')"/>
                                </td>
                            </tr>
                            <tr>
                                <td class="fa-label">Communication orale</td>
                                <td class="fa-value">
                                    <span t-esc="dict(o._fields['fa_communication_orale'].selection).get(o.fa_communication_orale, '')"/>
