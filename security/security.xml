<odoo>
  <data>
    <record id="module_category_ar_recrutement" model="ir.module.category">
      <field name="name">Recrutement</field>
      <field name="description">Droits d'acces du module AR Recrutement</field>
      <field name="sequence">36</field>
    </record>

    <record id="privilege_ar_recrutement_demandeur" model="res.groups.privilege">
      <field name="name">Recrutement - Demandeur</field>
      <field name="category_id" ref="ar_recrutement.module_category_ar_recrutement"/>
      <field name="sequence">10</field>
    </record>

    <record id="privilege_ar_recrutement_manager" model="res.groups.privilege">
      <field name="name">Recrutement - Manager N+1</field>
      <field name="category_id" ref="ar_recrutement.module_category_ar_recrutement"/>
      <field name="sequence">20</field>
    </record>

    <record id="privilege_ar_recrutement_rh" model="res.groups.privilege">
      <field name="name">Recrutement - RH</field>
      <field name="category_id" ref="ar_recrutement.module_category_ar_recrutement"/>
      <field name="sequence">30</field>
    </record>

    <record id="privilege_ar_recrutement_md" model="res.groups.privilege">
      <field name="name">Recrutement - Directeur (MD)</field>
      <field name="category_id" ref="ar_recrutement.module_category_ar_recrutement"/>
      <field name="sequence">40</field>
    </record>

    <function model="ir.model.data" name="write">
      <function model="ir.model.data" name="search">
        <value eval="[('module', '=', 'ar_recrutement'), ('name', 'in', [
          'group_ar_recrutement_demandeur',
          'group_ar_recrutement_manager',
          'group_ar_recrutement_rh',
          'group_ar_recrutement_md'
        ])]"/>
      </function>
      <value eval="{'noupdate': False}"/>
    </function>

    <record id="group_ar_recrutement_demandeur" model="res.groups">
      <field name="name">Actif</field>
      <field name="sequence">10</field>
      <field name="privilege_id" ref="ar_recrutement.privilege_ar_recrutement_demandeur"/>
    </record>

    <record id="group_ar_recrutement_manager" model="res.groups">
      <field name="name">Actif</field>
      <field name="sequence">10</field>
      <field name="privilege_id" ref="ar_recrutement.privilege_ar_recrutement_manager"/>
    </record>

    <record id="group_ar_recrutement_rh" model="res.groups">
      <field name="name">Actif</field>
      <field name="sequence">10</field>
      <field name="privilege_id" ref="ar_recrutement.privilege_ar_recrutement_rh"/>
    </record>

    <record id="group_ar_recrutement_md" model="res.groups">
      <field name="name">Actif</field>
      <field name="sequence">10</field>
      <field name="privilege_id" ref="ar_recrutement.privilege_ar_recrutement_md"/>
    </record>

    <function model="res.groups" name="write">
      <function model="res.groups" name="search">
        <value eval="[('id', '=', ref('ar_recrutement.group_ar_recrutement_demandeur'))]"/>
      </function>
      <value eval="{
        'name': 'Actif',
        'sequence': 10,
        'privilege_id': ref('ar_recrutement.privilege_ar_recrutement_demandeur')
      }"/>
    </function>

    <function model="res.groups" name="write">
      <function model="res.groups" name="search">
        <value eval="[('id', '=', ref('ar_recrutement.group_ar_recrutement_manager'))]"/>
      </function>
      <value eval="{
        'name': 'Actif',
        'sequence': 10,
        'privilege_id': ref('ar_recrutement.privilege_ar_recrutement_manager')
      }"/>
    </function>

    <function model="res.groups" name="write">
      <function model="res.groups" name="search">
        <value eval="[('id', '=', ref('ar_recrutement.group_ar_recrutement_rh'))]"/>
      </function>
      <value eval="{
        'name': 'Actif',
        'sequence': 10,
        'privilege_id': ref('ar_recrutement.privilege_ar_recrutement_rh')
      }"/>
    </function>

    <function model="res.groups" name="write">
      <function model="res.groups" name="search">
        <value eval="[('id', '=', ref('ar_recrutement.group_ar_recrutement_md'))]"/>
      </function>
      <value eval="{
        'name': 'Actif',
        'sequence': 10,
        'privilege_id': ref('ar_recrutement.privilege_ar_recrutement_md')
      }"/>
    </function>
  </data>
</odoo>
